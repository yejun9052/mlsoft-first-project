# =====================================================================
# 홈서버 데모 배포용 환경변수 템플릿 (커밋용 — 실제 값 넣지 말 것)
# 사용법: cp .env.prod.example .env.prod  (→ .env.prod는 .gitignore(.env.*)로 자동 제외)
#         docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# =====================================================================

# DB — mysql 컨테이너의 root 비밀번호. 아무 값이나 새로 정해서 채우면 됨(최초 1회만 이 값으로 DB 생성됨).
DB_PASSWORD=

# Google OAuth — Google Cloud Console에서 이 배포 도메인을 승인된 리디렉션 URI로 추가해야 함:
#   https://<FRONTEND_URL 아래 값>/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT 서명 키 — 32byte 이상 랜덤 문자열. 예: openssl rand -base64 32
JWT_SECRET=

# 로그인 허용 이메일 도메인 — 데모 때 로그인할 계정의 이메일 도메인으로 맞출 것
# (예: 개인 gmail 계정으로 로그인해서 시연할 거면 gmail.com)
ALLOWED_DOMAIN=

# 최초 로그인 시 SYSTEM_ADMIN을 부여할 이메일(콤마 구분) — 발표 시연 계정을 반드시 포함시킬 것
ADMIN_EMAILS=

# 프론트/백엔드가 합쳐진 단일 오리진 — Tailscale Funnel 공개 URL을 그대로 넣는다
# (docker compose로 앱을 먼저 한 번 띄운 뒤 `tailscale funnel 8080`으로 발급받은 https://*.ts.net 주소)
FRONTEND_URL=https://REPLACE-ME.ts.net

# 운영 배포이므로 반드시 true — false로 두면 앱이 기동을 거부한다(CookieSecurityCheck)
COOKIE_SECURE=true

# 아래 둘은 이번 데모 범위에서 안 쓰는 기능(이메일 발송·공휴일 API 미구현)이라 비워둬도 기동에는 지장 없음
MAIL_USERNAME=
MAIL_PASSWORD=
HOLIDAY_API_KEY=
